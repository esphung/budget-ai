{
	"name": "budgetai-server",
	"version": "0.1.0",
	"description": "Local Node.js backend for BudgetAI POC",
	"private": true,
	"scripts": {
		"dev": "npx ts-node-dev --respawn --exit-child --transpile-only src/index.ts",
		"build": "npx tsc",
		"start": "yarn build && node dist/index.js",
		"local": "npx nodemon src/index.ts",
		"test": "npx jest",
		"test:coverage": "npx jest --coverage"
	},
	"dependencies": {
		"axios": "^1.15.2",
		"cors": "^2.8.5",
		"dotenv": "^17.4.2",
		"express": "^4.19.2",
		"openai": "^6.34.0",
		"plaid": "^42.1.0"
	},
	"devDependencies": {
		"@jest/globals": "^30.3.0",
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/jest": "^30.0.0",
		"@types/node": "^20.14.0",
		"@types/supertest": "^7",
		"nodemon": "^3.1.14",
		"supertest": "^7.2.2",
		"ts-jest": "^29.4.9",
		"ts-node-dev": "^2.0.0",
		"typescript": "^5.5.2"
	}
}
