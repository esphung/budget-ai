{
	"extends": "@react-native/typescript-config",
	"compilerOptions": {
		"types": ["jest"],
		"paths": {
			"@components/*": ["./src/components/*"],
			"@screens/*": ["./src/screens/*"],
			"@assets/*": ["./src/assets/*"],
			"@utils/*": ["./src/utils/*"],
			"@hooks/*": ["./src/hooks/*"],
			"@services/*": ["./src/services/*"],
			"@models/*": ["./src/models/*"],
			"@context/*": ["./src/context/*"],
			"@navigation/*": ["./src/navigation/*"],
			"@theme/*": ["./src/theme/*"],
			"@enums/*": ["./src/enums/*"],
			"@stores/*": ["./src/stores/*"],
			"@providers/*": ["./src/providers/*"],
			"@mocks/*": ["./src/mocks/*"],
			"@repositories/*": ["./src/repositories/*"],
			"@db/*": ["./src/db/*"]
		}
	},
	"include": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx", "*.json"],
	"exclude": [
		"**/node_modules",
		"**/Pods",
		"**/build",
		"**/dist",
		"**/coverage"
	]
}
